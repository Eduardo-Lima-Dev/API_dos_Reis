### App
PORT=3003

### Supabase (Postgres)
# Use o Pooler (Transaction mode / 6543) para a API em produção.
# Exemplo (pooler):
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-...pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
#
# Use a conexão direta (5432) para migrations do Prisma (DIRECT_URL).
# Exemplo (direct):
# DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL=""
DIRECT_URL=""

### Supabase (Storage)
# URL do projeto (Project Settings → API → Project URL)
SUPABASE_URL=""

# Use Service Role key no backend (NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=""

# Nome do bucket para imagens
SUPABASE_IMAGES_BUCKET="images"
